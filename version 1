# programme principal
while True:
    # afficher le menu
    print("Menu :\n1-km en m\n2-m en km\n3-°C en °F\n4-°F en °C")

    # demander la réponse de l'utilisateur
    conversion = input ("Choisissez un conversion :")
    valeur = int(input("Entrez une valeur :"))

    # affichage du résultat
    if conversion == "1":
        valeur_convertie = valeur * 1000
        print("Résultat : %n", valeur_convertie)
    elif conversion == "2":
        valeur_convertie = valeur / 1000
        print("Résultat : %n", valeur_convertie)
    elif conversion == "3":
        valeur_convertie = valeur * 9/5 +32
        print("Résultat :%n", valeur_convertie)
    elif conversion == "4":
        valeur_convertie = valeur * 5/9 - 160/9
        print("Résultat :%n", valeur_convertie)



